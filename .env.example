LOCAL_MOCK_MODE=true
DETERMINISTIC_SEED=42
DISABLE_EXTERNAL_WRITES=true
SANAD_LLM=0          # set 1 only to enable the optional live reasoning call (has cached fallback)
SANAD_LIVE_EXTRACTION=0  # set 1 to parse the synthetic GOLDEN salary certificate from disk
SANAD_CERT_PATH=     # optional override path for the synthetic salary certificate text file

# T1 (Tooling Addendum) — orchestrator selection. plain = default, demo-safe.
# graph = officer portal may use /demo/run-graph (falls back to plain on error).
SANAD_ORCHESTRATOR=plain

# T2 (Tooling Addendum) — optional LangSmith-ready tracing. DISABLED by default.
# Redaction is unconditional: payloads pass redact_for_trace() before emission,
# and tracing+redaction-off refuses to emit at all.
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=agent-sanad-demo
TRACE_REDACTION=true
